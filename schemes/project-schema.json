{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://your-repo.com/schemas/project-schema.json",
  "title": "Project Profile Schema",
  "description": "Schema for validating detailed project profiles on the exchange",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "shortDescription", "links", "contractAddresses"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier (slug), only lowercase letters, numbers and hyphens"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Official project name"
    },
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,10}$",
      "description": "Token symbol (optional)"
    },
    "logoURI": {
      "type": "string",
      "format": "uri",
      "description": "Direct link to project logo"
    },
    "shortDescription": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Short description for preview"
    },
    "fullDescription": {
      "type": "string",
      "description": "Full description in Markdown"
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "website": { "type": "string", "format": "uri" },
        "whitepaper": { "type": "string", "format": "uri" },
        "github": { "type": "string", "format": "uri" },
        "twitter": { "type": "string", "format": "uri" },
        "telegram": { "type": "string", "format": "uri" },
        "discord": { "type": "string", "format": "uri" },
        "medium": { "type": "string", "format": "uri" },
        "explorer": { "type": "string", "format": "uri" }
      },
      "anyOf": [
        { "required": ["website"] },
        { "required": ["twitter"] },
        { "required": ["github"] }
      ]
    },
    "contractAddresses": {
      "type": "object",
      "description": "Contracts by network. Key is network identifier (xdc, eth, bsc...)",
      "patternProperties": {
        "^[0-9]+$": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "address"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "address": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" },
              "decimals": { "type": "integer", "minimum": 0, "maximum": 18 },
              "symbol": { "type": "string", "pattern": "^[A-Z0-9]{2,10}$" },
              "type": {
                "type": "string",
                "enum": ["token", "staking", "liquidity", "multisig", "other"]
              }
            }
          }
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "keyEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "title"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "link": { "type": "string", "format": "uri" }
        }
      }
    },
    "team": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "members": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "linkedin": { "type": "string", "format": "uri" },
              "github": { "type": "string", "format": "uri" },
              "avatarURI": { "type": "string", "format": "uri" }
            }
          }
        },
        "advisors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" }
            }
          }
        }
      }
    },
    "audits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "firm", "reportURI"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "firm": { "type": "string" },
          "reportURI": { "type": "string", "format": "uri" }
        }
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "screenshots": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        },
        "videoIntro": { "type": "string", "format": "uri" },
        "brandAssetsURI": { "type": "string", "format": "uri" }
      }
    },
    "isLaunched": { "type": "boolean" },
    "featured": { "type": "boolean" },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "seo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "maxLength": 70 },
        "description": { "type": "string", "maxLength": 160 },
        "keywords": { "type": "string" },
        "ogImage": { "type": "string", "format": "uri" },
        "ogType": { "type": "string", "enum": ["website", "article"] },
        "twitterCard": { "type": "string", "enum": ["summary", "summary_large_image"] },
        "canonicalUrl": { "type": "string", "format": "uri" },
        "noindex": { "type": "boolean" }
      }
    }
  }
}